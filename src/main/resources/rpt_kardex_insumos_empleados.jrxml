<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
	"http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
		http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="rpt_kardex_insumos_empleados"
	language="groovy"
	pageWidth="1050"
	pageHeight="595"
	orientation="Landscape"
	columnWidth="1010"
	leftMargin="20"
	rightMargin="20"
	topMargin="20"
	bottomMargin="20"
	uuid="5c220d8d-501d-4acd-9e8f-caebe9e12541">

	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.jrdax"/>

	<style name="ColumnHeader" fontName="Arial" fontSize="9" isBold="true" forecolor="#FFFFFF" backcolor="#1A1A2E" mode="Opaque"/>
	<style name="SummaryLabel" fontName="Arial" fontSize="9" isBold="true" forecolor="#1A1A2E"/>

	<queryString language="SQL"><![CDATA[SELECT
		k.id,
		i.nombre            AS ingrediente,
		um.nombre_unidad    AS unidad,
		m.nombre_movimiento AS movimiento,
		tm.operacion        AS tipo,
		k.cantidad,
		k.saldo_anterior,
		k.saldo_nuevo,
		k.fecha,
		u.name              AS usuario,
		u.email             AS email
	FROM kardex k
	JOIN ingrediente     i  ON i.id  = k.ingrediente_id
	JOIN unidad_medida  um  ON um.id = i.unidad_medida_id
	JOIN movimiento      m  ON m.id  = k.movimiento_id
	JOIN tipo_movimiento tm  ON tm.id = m.tipo_movimiento_id
	JOIN user            u  ON u.id  = k.usuario_id
	ORDER BY i.nombre, k.fecha DESC]]></queryString>

	<field name="id"             class="java.lang.Integer"/>
	<field name="ingrediente"    class="java.lang.String"/>
	<field name="unidad"         class="java.lang.String"/>
	<field name="movimiento"     class="java.lang.String"/>
	<field name="tipo"           class="java.lang.String"/>
	<field name="cantidad"       class="java.lang.Double"/>
	<field name="saldo_anterior" class="java.lang.Double"/>
	<field name="saldo_nuevo"    class="java.lang.Double"/>
	<field name="fecha"          class="java.sql.Timestamp"/>
	<field name="usuario"        class="java.lang.String"/>
	<field name="email"          class="java.lang.String"/>

	<variable name="TOTAL_ENTRADAS" class="java.lang.Double" calculation="Sum" resetType="Report">
		<variableExpression><![CDATA[$F{tipo}.equalsIgnoreCase("ENTRADA") ? $F{cantidad} : 0.0]]></variableExpression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_SALIDAS" class="java.lang.Double" calculation="Sum" resetType="Report">
		<variableExpression><![CDATA[$F{tipo}.equalsIgnoreCase("SALIDA") ? $F{cantidad} : 0.0]]></variableExpression>
		<initialValueExpression><![CDATA[0.0]]></initialValueExpression>
	</variable>
	<variable name="TOTAL_REGISTROS" class="java.lang.Integer" calculation="Count" resetType="Report">
		<variableExpression><![CDATA[$F{id}]]></variableExpression>
	</variable>

	<group name="grupoIngrediente" isStartNewPage="false" isReprintHeaderOnEachPage="true">
		<groupExpression><![CDATA[$F{ingrediente}]]></groupExpression>
		<groupHeader>
			<band height="18" splitType="Stretch">
				<rectangle>
					<reportElement x="0" y="0" width="1010" height="18" backcolor="#E8E5FF" forecolor="#E8E5FF" mode="Opaque"/>
					<graphicElement><pen lineWidth="0.0"/></graphicElement>
				</rectangle>
				<staticText>
					<reportElement x="6" y="2" width="60" height="14" forecolor="#534AB7"/>
					<textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
					<text><![CDATA[Insumo:]]></text>
				</staticText>
				<textField>
					<reportElement x="68" y="2" width="500" height="14" forecolor="#3C3489"/>
					<textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
					<textFieldExpression><![CDATA[$F{ingrediente} + "  (" + $F{unidad} + ")"]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
	</group>

	<background>
		<band splitType="Stretch"/>
	</background>

	<!-- â•â•â•â•â•â•â•â•â•â• TITLE â•â•â•â•â•â•â•â•â•â• -->
	<title>
		<band height="72" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="1010" height="72" backcolor="#1A1A2E" forecolor="#1A1A2E" mode="Opaque"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<rectangle>
				<reportElement x="0" y="0" width="5" height="72" backcolor="#5DCAA5" forecolor="#5DCAA5" mode="Opaque"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="18" y="10" width="280" height="26" forecolor="#FFFFFF"/>
				<textElement><font fontName="Georgia" size="18" isBold="true"/></textElement>
				<text><![CDATA[Cafe de Medianoche]]></text>
			</staticText>
			<staticText>
				<reportElement x="18" y="38" width="280" height="14" forecolor="#9FE1CB"/>
				<textElement><font fontName="Arial" size="9"/></textElement>
				<text><![CDATA[Sistema de Gestion de Inventario]]></text>
			</staticText>
			<staticText>
				<reportElement x="300" y="12" width="410" height="24" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center"><font fontName="Georgia" size="16" isBold="true"/></textElement>
				<text><![CDATA[Control de Movimientos de Inventario]]></text>
			</staticText>
			<staticText>
				<reportElement x="300" y="38" width="410" height="14" forecolor="#AFA9EC"/>
				<textElement textAlignment="Center"><font fontName="Arial" size="9"/></textElement>
				<text><![CDATA[Kardex de Insumos - Registro de Entradas y Salidas]]></text>
			</staticText>
			<staticText>
				<reportElement x="800" y="18" width="60" height="12" forecolor="#9FE1CB"/>
				<textElement textAlignment="Right"><font fontName="Arial" size="8"/></textElement>
				<text><![CDATA[Generado:]]></text>
			</staticText>
			<textField pattern="dd/MM/yyyy">
				<reportElement x="862" y="18" width="140" height="12" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<textField pattern="HH:mm">
				<reportElement x="862" y="32" width="140" height="12" forecolor="#9FE1CB"/>
				<textElement textAlignment="Right"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
		</band>
	</title>


	<!-- â•â•â•â•â•â•â•â•â•â• DETAIL â•â•â•â•â•â•â•â•â•â• -->
	<detail>
		<band height="16" splitType="Stretch">
			<rectangle>
				<reportElement x="0" y="0" width="1010" height="16" backcolor="#F8F7FF" forecolor="#F8F7FF" mode="Opaque">
					<printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
				</reportElement>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>
			<rectangle>
				<reportElement x="0" y="15" width="1010" height="1" backcolor="#E8E5FF" forecolor="#E8E5FF" mode="Opaque"/>
				<graphicElement><pen lineWidth="0.0"/></graphicElement>
			</rectangle>

			<textField>
				<reportElement x="2" y="2" width="30" height="12" forecolor="#888780"/>
				<textElement textAlignment="Center"><font fontName="Arial" size="7"/></textElement>
				<textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
			</textField>

			<textField pattern="dd/MM/yyyy HH:mm">
				<reportElement x="34" y="2" width="90" height="12" forecolor="#2C2C3A"/>
				<textElement textAlignment="Center"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{fecha}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="126" y="2" width="130" height="12" forecolor="#2C2C3A"/>
				<textElement><font fontName="Arial" size="8" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{ingrediente}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="258" y="2" width="52" height="12" forecolor="#534AB7"/>
				<textElement textAlignment="Center"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{unidad}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="312" y="2" width="120" height="12" forecolor="#2C2C3A"/>
				<textElement textAlignment="Center"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{movimiento}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="434" y="2" width="52" height="12" forecolor="#0F6E56">
					<printWhenExpression><![CDATA[$F{tipo}.equalsIgnoreCase("ENTRADA")]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center"><font fontName="Arial" size="7" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{tipo}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="434" y="2" width="52" height="12" forecolor="#993C1D">
					<printWhenExpression><![CDATA[$F{tipo}.equalsIgnoreCase("SALIDA")]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center"><font fontName="Arial" size="7" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{tipo}]]></textFieldExpression>
			</textField>

			<textField pattern="#,##0.000">
				<reportElement x="488" y="2" width="62" height="12" forecolor="#2C2C3A"/>
				<textElement textAlignment="Right"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>

			<textField pattern="#,##0.000">
				<reportElement x="552" y="2" width="64" height="12" forecolor="#5F5E5A"/>
				<textElement textAlignment="Right"><font fontName="Arial" size="8"/></textElement>
				<textFieldExpression><![CDATA[$F{saldo_anterior}]]></textFieldExpression>
			</textField>

			<textField pattern="#,##0.000">
				<reportElement x="618" y="2" width="64" height="12" forecolor="#0F6E56">
					<printWhenExpression><![CDATA[$F{saldo_nuevo} >= $F{saldo_anterior}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right"><font fontName="Arial" size="8" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{saldo_nuevo}]]></textFieldExpression>
			</textField>

			<textField pattern="#,##0.000">
				<reportElement x="618" y="2" width="64" height="12" forecolor="#993C1D">
					<printWhenExpression><![CDATA[$F{saldo_nuevo} < $F{saldo_anterior}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right"><font fontName="Arial" size="8" isBold="true"/></textElement>
				<textFieldExpression><![CDATA[$F{saldo_nuevo}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="684" y="2" width="80" height="12" forecolor="#444441"/>
				<textElement><font fontName="Arial" size="7"/></textElement>
				<textFieldExpression><![CDATA[$F{usuario}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="766" y="2" width="240" height="12" forecolor="#185FA5"/>
				<textElement><font fontName="Arial" size="7"/></textElement>
				<textFieldExpression><![CDATA[$F{email}]]></textFieldExpression>
			</textField>
		</band>
	</detail>

